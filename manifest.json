{
  "id": "family-fitness-challenge",
  "name": "Family Fitness Challenge",
  "version": "1.0.0",
  "description": "Run step, distance, or activity challenges with individual or team leaderboards, in-challenge streaks, and badges. Manual entry to start.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": ["fitness", "health", "competition", "family", "challenge"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_encryption": "off",
  "row_policies": {
    "ffc_challenges": {
      "kind": "adult_writable"
    },
    "ffc_teams": {
      "kind": "adult_writable"
    },
    "ffc_participants": {
      "kind": "adult_writable"
    },
    "ffc_entries": {
      "kind": "owner_or_visibility",
      "member_column": "member_id",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_owner_only": true
    }
  },
  "nav": { "label": "Fitness" },
  "widget": { "label": "Challenge", "size": "small" },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "🏃",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["active_challenges", "current_standings"]
  }
}
